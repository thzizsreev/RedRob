# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
env/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Large candidate datasets (download separately; sample JSONs backed up locally)
data/candidates.jsonl
data/candidates.jsonl.gz
data/sample*.json
!data/sample_candidates.json

# Track A precompute + Stage 1 + rank outputs (rebuild locally)
# Per-pool dirs: artifacts/sample1k/, sample5k/, candidates_full/, ...
#   precompute.py:
#     candidate_index.faiss, id_map.json, jd_query_vec.npy
#   stage1_cluster.py (Phase A):
#     stage1/candidate_vectors.npy, cluster_labels.npy, umap_reduced_12d.npy,
#     cluster_manifest.json
#   stage1.py (Phase B):
#     stage1/filtered_ids.json, filtered_metadata.json, cluster_rankings.json,
#     stage1_summary.json
#   rank.py: retrieval_results.json (when written under the pool dir)
artifacts/*
!artifacts/.gitkeep
artifacts/**
!artifacts/**/
!artifacts/**/.gitkeep

# INSTRUCTOR ONNX export output (regenerate: cd onnx && python export_to_onnx.py)
onnx/models/**
!onnx/models/
!onnx/models/.gitkeep

# Legacy scratch model dir at repo root (not onnx/models/)
/models/

# Naive track generated outputs
tracks/naive/artifacts/**
!tracks/naive/artifacts/
!tracks/naive/artifacts/.gitkeep

# Local environment and secrets
.env
.env.*

# Install / run logs
torch_install.log
*.log

# Test harness outputs (tests/run_clustering_test.py, tests/run_filtering_test.py, rank.py)
#   test_output/clustering/, test_output/filtering/, test_output/retrieval/
test_output/**
!test_output/
!test_output/.gitkeep

# Editor / IDE
.vscode/
.cursor/
.idea/

# OS junk
.DS_Store
Thumbs.db
