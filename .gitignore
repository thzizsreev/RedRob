# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.venv-*/
env/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Large candidate datasets (download separately; sample JSONs backed up locally)
data/candidates.jsonl
data/candidates.jsonl.gz
data/sample*.json
!data/sample_candidates.json

# Track A instructor pipeline outputs (rebuild via tracks/instructor/stage{0..5}/run.py)
#   artifacts/precomputed/: legacy global parquet paths (Stage 4/5 summaries)
#   artifacts/runtime/stage0/: FAISS index, id_map, candidate_vectors.npy, jd_query_vec.npy,
#       candidate_features.parquet (skill_weighted_score), stage3_query_vectors/, manifest
#   artifacts/runtime/stage1/: filtered_ids.json, cluster artifacts
#   artifacts/runtime/stage2/: stage2_gated.parquet, stage2_summary.json, removed logs
#   artifacts/runtime/stage3/: stage3_retrieved.parquet
#   artifacts/runtime/stage4/: stage4_reranked.parquet, stage4_rank_delta.csv
#   artifacts/runtime/stage5/: team_xxx.csv, stage5_scored.parquet, stage5_summary.json
artifacts/*
!artifacts/.gitkeep
artifacts/**
!artifacts/**/
!artifacts/**/.gitkeep

# Submission CSV if copied to repo root (canonical path: artifacts/runtime/stage5/)
team_*.csv

# INSTRUCTOR ONNX export output (regenerate: cd onnx && python export_to_onnx.py)
onnx/models/**
!onnx/models/
!onnx/models/.gitkeep

# Cross-encoder ONNX export (regenerate: python models/export_cross_encoder.py)
models/cross_encoder/**
!models/cross_encoder/
!models/cross_encoder/.gitkeep

# Legacy scratch dirs under models/ (export script + requirements.txt stay tracked)
models/encoder_test/
models/instructor_large_onnx/
models/ort_test/

# Generated HTML/JSON views (regenerate via tools/)
outputs/team_views/**
!outputs/team_views/
!outputs/team_views/.gitkeep
outputs/eliminations/**
!outputs/eliminations/
!outputs/eliminations/.gitkeep
outputs/test_runs/**
!outputs/test_runs/
!outputs/test_runs/.gitkeep

# Legacy root-level view dirs (pre-reorg)
team_results_view*/

# Naive track generated outputs
tracks/naive/artifacts/**
!tracks/naive/artifacts/
!tracks/naive/artifacts/.gitkeep

# build_collection.py default output (outside repo, but ignore if created here)
stage4_reranked_collection/

# Local environment and secrets
.env
.env.*

# Install / run logs
torch_install.log
*.log

# Stage 3 skill-track test harness (regenerate: experiments/stage3/precompute/run.py → runner/run.py)
experiments/stage3/precompute/artifacts/**
!experiments/stage3/precompute/artifacts/
!experiments/stage3/precompute/artifacts/.gitkeep
experiments/stage3/runner/outputs/**
!experiments/stage3/runner/outputs/
!experiments/stage3/runner/outputs/.gitkeep

# K-means experiment outputs
experiments/kmeans/precomputed/**
experiments/kmeans/outputs/**

# Honeypot research pipeline outputs
experiments/honeypot/output/**
!experiments/honeypot/output/
!experiments/honeypot/output/.gitkeep

# K-means filter scratch (experimental Stage 1 alternative)
data/filter_kmeans/

# Editor / IDE
.vscode/
.cursor/
.idea/

# OS junk
.DS_Store
Thumbs.db
