# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
env/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Large candidate datasets (download separately; sample JSONs backed up locally)
data/candidates.jsonl
data/candidates.jsonl.gz
data/sample*.json
!data/sample_candidates.json

# Precompute + rank outputs (rebuild with precompute.py / rank.py; backed up locally)
# Per-sample dirs: artifacts/sample1k/, sample5k/, sample10k/, sample20k/, ...
artifacts/*
!artifacts/.gitkeep
artifacts/**
!artifacts/**/
!artifacts/**/.gitkeep
artifacts/anchors/*.npy

# INSTRUCTOR ONNX export output (regenerate: cd onnx && python export_to_onnx.py)
onnx/models/**
!onnx/models/
!onnx/models/.gitkeep

# Legacy scratch model dir at repo root (not onnx/models/)
/models/

# Naivee generated outputs
naivee/artifacts/**
!naivee/artifacts/
!naivee/artifacts/.gitkeep

# Local environment and secrets
.env
.env.*

# Install / run logs
torch_install.log
*.log

# Clustering + retrieval test outputs (test/run_clustering_test.py, rank.py)
test_output/**
!test_output/
!test_output/.gitkeep
